# Application
LOG_LEVEL=DEBUG
PORT=9000
TRUSTED_PROXIES=""
FRONTEND_URL="http://localhost:3000"
SALT_ROUNDS=12
DOMAIN="localhost"
ENVIRONMENT="development"

# Database
DATABASE_URL="postgres://postgres:password@localhost:5432/easyflow-oauth2-server?sslmode=disable"
MIGRATIONS_PATH=pkg/database/sql/migrations

# Valkey
VALKEY_URL=127.0.0.1:6379
VALKEY_USERNAME=default
VALKEY_PASSWORD=
VALKEY_CLIENT_NAME=easyflow-oauth2-server

# JWT
JWT_ISSUER="localhost:9000"
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7
JWT_SESSION_TOKEN_EXPIRY_HOURS=1
JWT_SECRET="aaaabbbbccccddddeeeeffffgggghhhh"
